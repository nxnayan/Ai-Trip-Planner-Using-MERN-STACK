# Auto-detect text files and normalize line endings
* text=auto

# Force LF for common source files to keep repo consistent
*.sh text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.json text eol=lf
*.js text eol=lf
*.jsx text eol=lf
*.ts text eol=lf
*.tsx text eol=lf
*.css text eol=lf
*.scss text eol=lf
*.html text eol=lf
*.md text eol=lf

# Binary files — do not modify
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.zip binary
*.gz binary
*.jar binary

# Ignore git's eol conversion warnings for lockfiles/build artifacts
package-lock.json text eol=lf
yarn.lock text eol=lf
